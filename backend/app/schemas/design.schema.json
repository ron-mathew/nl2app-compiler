{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SystemDesign",
  "description": "Stage 2 output — app architecture, pages, roles, entity relationships",
  "type": "object",
  "required": ["pages", "roles", "role_permission_matrix", "entity_relationships", "business_rules", "canonical_entity_names"],
  "properties": {
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "route", "access", "components", "connected_endpoints"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "route": { "type": "string", "pattern": "^/" },
          "access": {
            "oneOf": [
              { "type": "string", "enum": ["public"] },
              { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            ]
          },
          "components": { "type": "array", "items": { "type": "string" } },
          "connected_endpoints": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" }
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "role_permission_matrix": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "entity_relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "type": { "type": "string", "enum": ["one_to_one", "one_to_many", "many_to_many", "many_to_one"] },
          "description": { "type": "string" }
        }
      }
    },
    "business_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "canonical_entity_names": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "data_flows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "trigger": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
