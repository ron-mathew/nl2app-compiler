{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntentIR",
  "description": "Stage 1 output — structured intermediate representation of user intent",
  "type": "object",
  "required": ["app_name", "app_type", "entities", "actors", "features", "ambiguity_flags", "assumptions"],
  "properties": {
    "app_name": { "type": "string", "minLength": 1 },
    "app_type": {
      "type": "string",
      "enum": ["web_application", "mobile_application", "api_service", "dashboard", "marketplace", "saas_platform"]
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "attributes"],
        "properties": {
          "name": { "type": "string" },
          "attributes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["target", "type"],
              "properties": {
                "target": { "type": "string" },
                "type": { "type": "string", "enum": ["one_to_one", "one_to_many", "many_to_many", "many_to_one"] }
              }
            }
          }
        }
      }
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "capabilities"],
        "properties": {
          "name": { "type": "string" },
          "capabilities": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["auth", "crud", "analytics", "billing", "rbac", "search", "notifications", "file_upload", "real_time", "reporting", "other"]
          },
          "details": { "type": "string" },
          "payment_required": { "type": "boolean" },
          "entity": { "type": "string" }
        }
      }
    },
    "ambiguity_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": { "type": "string", "enum": ["vague", "conflicting", "underspecified", "unrealistic"] },
          "description": { "type": "string" },
          "resolution": { "type": "string" }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "clarification_needed": { "type": "boolean" },
    "clarification_questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
